*.backup.backup

# Virtual environments
.venv/
venv/
env/

# macOS
.DS_Store

# VS Code
.vscode/

# Local app config and secrets
.env
config.json
*.log

# Generated outputs / artifacts
exports/
archive/
models/*.pkl

# Web frontend build artifacts
web/frontend/node_modules/
npm-debug.log*

# Ignore those external repos if you keep them in the folder
SuperClaude/
SuperClaude_Framework/

# Claude Code per-project state
.claude/

# Local runtime data — mirror of $HOME/.options_calculator_pro/, not source
.options_calculator_pro/

# pytest auto-isolation directories (HOME redirect set by conftest.py + pytest cache)
.pytest_home/
.pytest_cache/

# Additional virtualenvs the team uses (current rule covers .venv/ only)
.venv_arm64/
.venv313/
.venv-replay180/

# macOS-style local cache appearing under the project root
Library/

# Local scratch — backtest CSVs, log files, PID files, throwaway DBs
tmp/

# Vite build output (no per-folder .gitignore exists under web/frontend/)
web/frontend/dist/

# Validation report artefacts (P-5 baseline captures, real corpus, etc.)
reports/

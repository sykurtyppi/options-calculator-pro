# MarketData.app API token — get yours at https://www.marketdata.app/
# 100,000 credits/day on paid plans. Free tier: 100 req/day.
MARKETDATA_TOKEN=your_token_here

# Alpha Vantage earnings calendar — best used as a cached bulk discovery feed.
# Official free-tier support currently documents up to 25 requests/day.
ALPHA_VANTAGE_API_KEY=

# Financial Modeling Prep — optional secondary calendar / confirmed-earnings source.
FMP_API_KEY=

# SEC EDGAR API user agent for confirmation lookups.
# Example: your-email@example.com options-calculator-pro/1.0
SEC_API_USER_AGENT=

# Optional iMessage watchdog alerts for the daily evidence cycle.
# Use the phone number or Apple ID reachable from Messages on this Mac.
WATCHDOG_IMESSAGE_TO=

# CORS origins for the FastAPI backend (comma-separated)
OPTIONS_CALCULATOR_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional share-code auth for shared deployments
ENABLE_SHARE_AUTH=false
SHARE_PASSWORD=
SESSION_SECRET=change-me-in-env

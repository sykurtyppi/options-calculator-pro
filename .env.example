# MarketData.app API token — get yours at https://www.marketdata.app/
# 100,000 credits/day on paid plans. Free tier: 100 req/day.
MARKETDATA_TOKEN=your_token_here

# CORS origins for the FastAPI backend (comma-separated)
OPTIONS_CALCULATOR_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional share-code auth for shared deployments
ENABLE_SHARE_AUTH=false
SHARE_PASSWORD=
SESSION_SECRET=change-me-in-env
